{
  "name": "ai-db-service",
  "version": "1.0.0",
  "description": "AI-powered natural language interface for PostgreSQL",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "cli": "node src/cli.js",
    "db:seed": "node src/seeds/index.js",
    "db:push": "npx drizzle-kit push",
    "db:generate": "npx drizzle-kit generate --config=drizzle.config.js",
    "db:migrate": "npx drizzle-kit migrate --config=drizzle.config.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@medusajs/js-sdk": "^2.15.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4"
  }
}
